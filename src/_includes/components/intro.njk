<header id="intro" class="t__section intro">
    <div class="t__container">
        {% if layout == 'layouts/base' %}
            <figure class="intro__avatar">
                {% include 'components/avatar.njk' %}
                <div class="intro__avatar__ascii">
                    {% include 'assets/ascii.svg' %}
                </div>
            </figure>
        {% endif %}
        <h1 class="intro__logo">
            <a href="/">
                <span class="t__vh">{{ site.author }}</span>
                {% include 'assets/logo.svg' %}
            </a>
        </h1>
        <nav class="intro__nav">
            <ul>
                <li>
                    <a href="/" class="intro__nav-link {% if page.url == '/' %}intro__nav-link--active{% endif %}">Home</a>
                </li>
                <li>
                    <a href="/#works" class="intro__nav-link">Case studies</a>
                    <span>&</span>
                    <a href="/projects/" class="intro__nav-link {% if page.url == '/projects/' %}intro__nav-link--active{% endif %}">Projects</a>
                </li>
                <li>
                    <a href="/about/" class="intro__nav-link {% if page.url == '/about/' %}intro__nav-link--active{% endif %}">About me</a>
                </li>
                <li>
                    <a href="#contact" class="intro__nav-link">Get in touch</a>
                </li>
            </ul>
        </nav>
        {% if page.url == '/' %}
            <p class="intro__text">I am a Staff Product Designer at <a href="https://www.analog.com/" target="_blank" rel="noopener noreferrer" class="intro__company">{% include 'assets/analog-devices.svg' %}<span class="t__vh">Analog Devices</span></a>, where I shape the digital tools that power the physical world. With over {% experienceYears %} of experience, I bridge the gap between sophisticated hardware and intuitive user experience, transforming how engineers and enterprises interact with technology.</p>
        {% endif %}
    </div>
</header>